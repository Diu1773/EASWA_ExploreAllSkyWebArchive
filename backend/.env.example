# Local development defaults
EASWA_DEBUG=true
EASWA_HOST=0.0.0.0
EASWA_PORT=5895
EASWA_BASE_URL=http://localhost:5895
EASWA_SESSION_SECRET=easwa-dev-secret-change-me

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Runtime storage
EASWA_DB_PATH=./easwa.dev.db
EASWA_EXPORT_DIR=./submissions-dev

# Transit performance knobs
EASWA_TRANSIT_PREVIEW_WORKERS=2
EASWA_TRANSIT_FRAME_COUNT_WORKERS=4
EASWA_TRANSIT_CUTOUT_MEMORY_CACHE_MAX_ITEMS=4
EASWA_TRANSIT_CUTOUT_MEMORY_CACHE_MAX_BYTES=209715200
EASWA_TRANSIT_CUTOUT_HOT_CACHE_MAX_ITEMS=1

# App behavior
EASWA_RECORD_REQUIRE_LOGIN=true
